{
  "name": "nanobanana-storyboarder",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:server": "cd server && npx vitest run",
    "test:all": "vitest run && cd server && npx vitest run",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:headed": "npx playwright test --headed",
    "test:e2e:real": "cross-env REAL_API=true npx playwright test --headed",
    "test:e2e:real:headless": "cross-env REAL_API=true npx playwright test",
    "server": "cd server && npx tsx watch src/index.ts",
    "start": "cd server && npx tsx src/index.ts"
  },
  "dependencies": {
    "@google/genai": "^1.33.0",
    "file-saver": "2.0.5",
    "jszip": "3.10.1",
    "lucide-react": "^0.560.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-virtuoso": "^4.18.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/express": "^5.0.6",
    "@types/node": "^22.14.0",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.27",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "postcss": "^8.5.6",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.0"
  }
}
