{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true,
        "typeRoots": [
            "../server/node_modules/@types",
            "../node_modules/@types"
        ],
        "baseUrl": ".",
        "paths": {
            "supertest": [
                "../server/node_modules/supertest"
            ],
            "express": [
                "../server/node_modules/@types/express"
            ]
        }
    },
    "include": [
        "./**/*.test.ts"
    ]
}